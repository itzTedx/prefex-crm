# ---------------------------------------------------------------
# Perfex CRM — Dokploy Environment Variables
# Copy these into Dokploy → your Compose service → Environment tab
# Never commit a real .env file with actual secrets to git
# ---------------------------------------------------------------

# ---------------------------------------------------------------
# MySQL Database
# ---------------------------------------------------------------

# Root password for the MySQL container
MYSQL_ROOT_PASSWORD=replace_with_strong_root_password

# Database name, user, and password that Perfex CRM will use.
# Enter these same values into the web installer when prompted.
MYSQL_DATABASE=perfex_crm
MYSQL_USER=perfex
MYSQL_PASSWORD=replace_with_strong_db_password

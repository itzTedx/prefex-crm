# Large build artifact — never commit the zip
perfex_crm.zip

# Node
node_modules/

# Composer vendor (already committed from Envato package; adjust if needed)
# application/vendor/

# Cursor IDE
.cursor/

# Logs and caches generated at runtime
application/logs/*.php
application/cache/*
!application/cache/index.html

# Runtime upload and temp dirs (mount as Docker volumes)
uploads/*
!uploads/index.html
temp/*
!temp/index.html

# Generated app config (created by docker-entrypoint.sh at runtime)
application/config/app-config.php

# OS
.DS_Store
Thumbs.db
